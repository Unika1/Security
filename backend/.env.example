# Backend environment variables — copy this file to .env and fill in values.
PORT=5000

# The frontend's address — allowed to call this backend (CORS).
CLIENT_ORIGIN=http://localhost:3000

# Local MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/citymate

# Secret used to sign JWT login tokens. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string

# Email (2FA OTP). Leave EMAIL_USER/PASS empty to use a free Ethereal test inbox.
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=CityMate <no-reply@citymate.local>
